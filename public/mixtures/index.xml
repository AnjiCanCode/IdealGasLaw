    <item>
      <title>Dalton&#39;s Law</title>
      <link>//localhost:1313/mixtures/1_dalton.html</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>//localhost:1313/mixtures/1_dalton.html</guid>
      <description>&lt;div class=&#34;page&#34;&gt;&#xA;&lt;div class=&#34;stepLog twoColumn&#34;&gt;&#xA;&#xA;&lt;script&gt;&#xA;    var sim = createSimulation({&#xA;        initialize: function(simulation) {&#xA;&#x9;&#x9;&#x9;var p = simulation.parameters;&#xA;&#x9;&#x9;&#x9;p.isOnlyHardSpheres = true;&#xA;&#x9;&#x9;&#x9;setBoxWidth(simulation, 80);&#xA;&#xA;&#x9;&#x9;&#x9;// Type A particles (default black)&#xA;&#x9;&#x9;&#x9;var countA = 60;&#xA;&#x9;&#x9;&#x9;for (var i = 0; i &lt; countA; i++) {&#xA;&#x9;&#x9;&#x9;&#x9;var particle = new Particle();&#xA;&#x9;&#x9;&#x9;&#x9;particle.type = 0;&#xA;&#x9;&#x9;&#x9;&#x9;randomDiscInRect(particle.position, particle.radius, simulation.boxBounds);&#xA;&#x9;&#x9;&#x9;&#x9;v2.set(particle.velocity, randomGaussian(), randomGaussian());&#xA;&#x9;&#x9;&#x9;&#x9;v2.scale(particle.velocity, particle.velocity, 8);&#xA;&#x9;&#x9;&#x9;&#x9;addParticle(simulation, particle);&#xA;&#x9;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;&#x9;// Type B particles (red)&#xA;&#x9;&#x9;&#x9;var countB = 40;&#xA;&#x9;&#x9;&#x9;for (var i = 0; i &lt; countB; i++) {&#xA;&#x9;&#x9;&#x9;&#x9;var particle = new Particle();&#xA;&#x9;&#x9;&#x9;&#x9;particle.type = 1;&#xA;&#x9;&#x9;&#x9;&#x9;particle.color = Color.red;&#xA;&#x9;&#x9;&#x9;&#x9;randomDiscInRect(particle.position, particle.radius, simulation.boxBounds);&#xA;&#x9;&#x9;&#x9;&#x9;v2.set(particle.velocity, randomGaussian(), randomGaussian());&#xA;&#x9;&#x9;&#x9;&#x9;v2.scale(particle.velocity, particle.velocity, 8);&#xA;&#x9;&#x9;&#x9;&#x9;addParticle(simulation, particle);&#xA;&#x9;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;&#x9;setToolbarAvailableTools(simulation.toolbar, [&#34;move&#34;, &#34;create&#34;]);&#xA;        },&#xA;    });&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h2&gt;Dalton&#39;s Law of Partial Pressures&lt;/h2&gt;&#xA;&#xA;&lt;p&gt;What happens when you mix different gases together?&lt;/p&gt;</description>
    </item>
    <item>
      <title>Non-Ideal Mixtures</title>
      <link>//localhost:1313/mixtures/2_nonideal.html</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>//localhost:1313/mixtures/2_nonideal.html</guid>
      <description>&lt;div class=&#34;page&#34;&gt;&#xA;&lt;div class=&#34;stepLog twoColumn&#34;&gt;&#xA;&#xA;&lt;script&gt;&#xA;    var sim = createSimulation({&#xA;        initialize: function(simulation) {&#xA;&#x9;&#x9;&#x9;var p = simulation.parameters;&#xA;&#x9;&#x9;&#x9;p.thermostatDeterministicStrength = 0.3;&#xA;&#x9;&#x9;&#x9;p.thermostatTemperature = 8;&#xA;&#x9;&#x9;&#x9;setBoxWidth(simulation, 80);&#xA;&#xA;&#x9;&#x9;&#x9;// Type A particles&#xA;&#x9;&#x9;&#x9;var countA = 50;&#xA;&#x9;&#x9;&#x9;for (var i = 0; i &lt; countA; i++) {&#xA;&#x9;&#x9;&#x9;&#x9;var particle = new Particle();&#xA;&#x9;&#x9;&#x9;&#x9;particle.type = 0;&#xA;&#x9;&#x9;&#x9;&#x9;randomDiscInRect(particle.position, particle.radius, simulation.boxBounds);&#xA;&#x9;&#x9;&#x9;&#x9;v2.set(particle.velocity, randomGaussian(), randomGaussian());&#xA;&#x9;&#x9;&#x9;&#x9;v2.scale(particle.velocity, particle.velocity, 6);&#xA;&#x9;&#x9;&#x9;&#x9;addParticle(simulation, particle);&#xA;&#x9;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;&#x9;// Type B particles (red)&#xA;&#x9;&#x9;&#x9;var countB = 50;&#xA;&#x9;&#x9;&#x9;for (var i = 0; i &lt; countB; i++) {&#xA;&#x9;&#x9;&#x9;&#x9;var particle = new Particle();&#xA;&#x9;&#x9;&#x9;&#x9;particle.type = 1;&#xA;&#x9;&#x9;&#x9;&#x9;particle.color = Color.red;&#xA;&#x9;&#x9;&#x9;&#x9;randomDiscInRect(particle.position, particle.radius, simulation.boxBounds);&#xA;&#x9;&#x9;&#x9;&#x9;v2.set(particle.velocity, randomGaussian(), randomGaussian());&#xA;&#x9;&#x9;&#x9;&#x9;v2.scale(particle.velocity, particle.velocity, 6);&#xA;&#x9;&#x9;&#x9;&#x9;addParticle(simulation, particle);&#xA;&#x9;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;&#x9;// Set up interactions&#xA;&#x9;&#x9;&#x9;var ljAA = new LennardJonesInteraction();&#xA;&#x9;&#x9;&#x9;ljAA.strength = 3;&#xA;&#x9;&#x9;&#x9;setInteraction(simulation, 0, 0, ljAA);&#xA;&#xA;&#x9;&#x9;&#x9;var ljBB = new LennardJonesInteraction();&#xA;&#x9;&#x9;&#x9;ljBB.strength = 3;&#xA;&#x9;&#x9;&#x9;setInteraction(simulation, 1, 1, ljBB);&#xA;&#xA;&#x9;&#x9;&#x9;var ljAB = new LennardJonesInteraction();&#xA;&#x9;&#x9;&#x9;ljAB.strength = 3;&#xA;&#x9;&#x9;&#x9;setInteraction(simulation, 0, 1, ljAB);&#xA;&#xA;&#x9;&#x9;&#x9;setToolbarAvailableTools(simulation.toolbar, [&#34;move&#34;, &#34;repel&#34;]);&#xA;        },&#xA;    });&#xA;&#xA;    var crossInteractionStrength = 3;&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h2&gt;Non-Ideal Mixtures&lt;/h2&gt;&#xA;&#xA;&lt;p&gt;Real molecules interact differently depending on what they&#39;re near. A-A interactions might differ from A-B interactions.&lt;/p&gt;</description>
    </item>
