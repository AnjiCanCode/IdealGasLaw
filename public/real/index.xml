    <item>
      <title>Excluded Volume</title>
      <link>//localhost:1313/real/1_excluded_volume.html</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>//localhost:1313/real/1_excluded_volume.html</guid>
      <description>&lt;div class=&#34;page&#34;&gt;&#xA;&lt;div class=&#34;stepLog twoColumn&#34;&gt;&#xA;&#xA;&lt;script&gt;&#xA;    var sim = createSimulation({&#xA;        initialize: function(simulation) {&#xA;&#x9;&#x9;&#x9;var p = simulation.parameters;&#xA;&#x9;&#x9;&#x9;p.isOnlyHardSpheres = true;&#xA;&#x9;&#x9;&#x9;p.thermostatDeterministicStrength = 0.5;&#xA;&#x9;&#x9;&#x9;p.thermostatTemperature = 10;&#xA;&#x9;&#x9;&#x9;setBoxWidth(simulation, 80);&#xA;&#xA;&#x9;&#x9;&#x9;var particleCount = 60;&#xA;&#x9;&#x9;&#x9;for (var i = 0; i &lt; particleCount; i++) {&#xA;&#x9;&#x9;&#x9;&#x9;var particle = new Particle();&#xA;&#x9;&#x9;&#x9;&#x9;randomDiscInRect(particle.position, particle.radius, simulation.boxBounds);&#xA;&#x9;&#x9;&#x9;&#x9;v2.set(particle.velocity, randomGaussian(), randomGaussian());&#xA;&#x9;&#x9;&#x9;&#x9;v2.scale(particle.velocity, particle.velocity, 6);&#xA;&#x9;&#x9;&#x9;&#x9;addParticle(simulation, particle);&#xA;&#x9;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;&#x9;setToolbarAvailableTools(simulation.toolbar, [&#34;move&#34;, &#34;create&#34;]);&#xA;        },&#xA;    });&#xA;&#xA;    var currentBoxWidth = 80;&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h2&gt;Real Particles Take Up Space&lt;/h2&gt;&#xA;&#xA;&lt;p&gt;The ideal gas law assumes particles are &lt;strong&gt;infinitely small points&lt;/strong&gt;. But real molecules have size!&lt;/p&gt;</description>
    </item>
    <item>
      <title>Intermolecular Attraction</title>
      <link>//localhost:1313/real/2_attraction.html</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>//localhost:1313/real/2_attraction.html</guid>
      <description>&lt;div class=&#34;page&#34;&gt;&#xA;&lt;div class=&#34;stepLog twoColumn&#34;&gt;&#xA;&#xA;&lt;script&gt;&#xA;    var sim = createSimulation({&#xA;        initialize: function(simulation) {&#xA;&#x9;&#x9;&#x9;var p = simulation.parameters;&#xA;&#x9;&#x9;&#x9;p.thermostatDeterministicStrength = 0.5;&#xA;&#x9;&#x9;&#x9;p.thermostatTemperature = 8;&#xA;&#x9;&#x9;&#x9;setBoxWidth(simulation, 80);&#xA;&#xA;&#x9;&#x9;&#x9;var particleCount = 100;&#xA;&#x9;&#x9;&#x9;var particles = [];&#xA;&#x9;&#x9;&#x9;for (var i = 0; i &lt; particleCount; i++) {&#xA;&#x9;&#x9;&#x9;&#x9;var particle = new Particle();&#xA;&#x9;&#x9;&#x9;&#x9;particles.push(particle);&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;addParticlesRandomlyAround(simulation, particles, v2(0, 0));&#xA;&#xA;&#x9;&#x9;&#x9;var ljInteraction = new LennardJonesInteraction();&#xA;&#x9;&#x9;&#x9;ljInteraction.strength = 5;&#xA;&#x9;&#x9;&#x9;setInteraction(simulation, 0, 0, ljInteraction);&#xA;&#xA;&#x9;&#x9;&#x9;setToolbarAvailableTools(simulation.toolbar, [&#34;move&#34;, &#34;repel&#34;]);&#xA;        },&#xA;    });&#xA;&#xA;    var attractionStrength = 5;&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h2&gt;Real Particles Attract Each Other&lt;/h2&gt;&#xA;&#xA;&lt;p&gt;The second way real gases differ from ideal: molecules &lt;strong&gt;attract each other&lt;/strong&gt; through van der Waals forces.&lt;/p&gt;</description>
    </item>
