    <item>
      <title>PV = nRT</title>
      <link>//localhost:1313/ideal/3_pvnrt/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>//localhost:1313/ideal/3_pvnrt/</guid>
      <description>&lt;div class=&#34;page&#34;&gt;&#xA;&lt;div class=&#34;stepLog twoColumn&#34;&gt;&#xA;&#xA;&lt;script&gt;&#xA;    var sim = createSimulation({&#xA;        initialize: function(simulation) {&#xA;&#x9;&#x9;&#x9;var p = simulation.parameters;&#xA;&#x9;&#x9;&#x9;p.isOnlyHardSpheres = true;&#xA;&#x9;&#x9;&#x9;p.thermostatDeterministicStrength = 1;&#xA;&#x9;&#x9;&#x9;p.thermostatTemperature = 10;&#xA;&#x9;&#x9;&#x9;setBoxWidth(simulation, 80);&#xA;&#x9;&#x9;&#x9;setWallsAlongBorder(simulation);&#xA;&#xA;&#x9;&#x9;&#x9;var particleCount = 100;&#xA;&#x9;&#x9;&#x9;for (var i = 0; i &lt; particleCount; i++) {&#xA;&#x9;&#x9;&#x9;&#x9;var particle = new Particle();&#xA;&#x9;&#x9;&#x9;&#x9;randomDiscInRect(particle.position, particle.radius, simulation.boxBounds);&#xA;&#x9;&#x9;&#x9;&#x9;v2.set(particle.velocity, randomGaussian(), randomGaussian());&#xA;&#x9;&#x9;&#x9;&#x9;v2.scale(particle.velocity, particle.velocity, 1.5);&#xA;&#x9;&#x9;&#x9;&#x9;addParticle(simulation, particle);&#xA;&#x9;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;&#x9;setToolbarAvailableTools(simulation.toolbar, [&#34;move&#34;, &#34;create&#34;]);&#xA;        },&#xA;    });&#xA;&#xA;    var currentBoxWidth = 80;&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h2&gt;Putting It Together: PV = nRT&lt;/h2&gt;&#xA;&#xA;&lt;div class=&#34;equation&#34;&gt;PV = nRT&lt;/div&gt;&#xA;&#xA;&lt;p&gt;This is the &lt;strong&gt;ideal gas law&lt;/strong&gt;. It combines everything we&#39;ve seen:&lt;/p&gt;</description>
    </item>
