    <item>
      <title>Free Exploration</title>
      <link>//localhost:1313/playground/1_explore/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>//localhost:1313/playground/1_explore/</guid>
      <description>&lt;div class=&#34;page&#34;&gt;&#xA;&lt;div class=&#34;twoColumn&#34;&gt;&#xA;&#xA;&lt;h2&gt;Playground&lt;/h2&gt;&#xA;&#xA;&lt;p&gt;All the controls, no restrictions. Explore freely!&lt;/p&gt;&#xA;&#xA;&lt;script&gt;&#xA;    var sim = createSimulation({&#xA;        initialize: function(simulation) {&#xA;&#x9;&#x9;&#x9;var p = simulation.parameters;&#xA;&#x9;&#x9;&#x9;p.thermostatDeterministicStrength = 0.5;&#xA;&#x9;&#x9;&#x9;p.thermostatTemperature = 10;&#xA;&#x9;&#x9;&#x9;setBoxWidth(simulation, 80);&#xA;&#x9;&#x9;&#x9;setWallsAlongBorder(simulation);&#xA;&#xA;&#x9;&#x9;&#x9;var particleCount = 80;&#xA;&#x9;&#x9;&#x9;for (var i = 0; i &lt; particleCount; i++) {&#xA;&#x9;&#x9;&#x9;&#x9;var particle = new Particle();&#xA;&#x9;&#x9;&#x9;&#x9;randomDiscInRect(particle.position, particle.radius, simulation.boxBounds);&#xA;&#x9;&#x9;&#x9;&#x9;v2.set(particle.velocity, randomGaussian(), randomGaussian());&#xA;&#x9;&#x9;&#x9;&#x9;v2.scale(particle.velocity, particle.velocity, 1.5);&#xA;&#x9;&#x9;&#x9;&#x9;addParticle(simulation, particle);&#xA;&#x9;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;&#x9;setToolbarAvailableTools(simulation.toolbar, [&#34;move&#34;, &#34;create&#34;, &#34;attract&#34;, &#34;repel&#34;, &#34;delete&#34;]);&#xA;        },&#xA;    });&#xA;&#xA;    var currentBoxWidth = 80;&#xA;    var currentAttractionStrength = 0;&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h3&gt;Volume&lt;/h3&gt;&#xA;&lt;script&gt;&#xA;&#x9;createSliderHere({&#xA;&#x9;&#x9;initialValue: 80,&#xA;&#x9;&#x9;min: 15, max: 120,&#xA;&#x9;&#x9;minLabel: &#34;Tiny&#34;, maxLabel: &#34;Huge&#34;,&#xA;&#x9;&#x9;update: function(value)&#xA;&#x9;&#x9;{&#xA;&#x9;&#x9;&#x9;currentBoxWidth = value;&#xA;&#x9;&#x9;&#x9;setBoxWidth(sim, value);&#xA;&#x9;&#x9;&#x9;setWallsAlongBorder(sim);&#xA;&#x9;&#x9;},&#xA;&#x9;});&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h3&gt;Temperature&lt;/h3&gt;&#xA;&lt;script&gt;&#xA;&#x9;createSliderHere({&#xA;&#x9;&#x9;initialValue: 10,&#xA;&#x9;&#x9;min: 0.1, max: 80,&#xA;&#x9;&#x9;minLabel: &#34;Freezing&#34;, maxLabel: &#34;Blazing&#34;,&#xA;&#x9;&#x9;transform: function(x) { return (x * x) },&#xA;&#x9;&#x9;inverseTransform: function(x) { return Math.sqrt(x) },&#xA;&#x9;&#x9;update: function(value)&#xA;&#x9;&#x9;{&#xA;&#x9;&#x9;&#x9;sim.parameters.thermostatTemperature = value;&#xA;&#x9;&#x9;},&#xA;&#x9;});&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h3&gt;Attraction Strength&lt;/h3&gt;&#xA;&lt;script&gt;&#xA;&#x9;createSliderHere({&#xA;&#x9;&#x9;initialValue: 0,&#xA;&#x9;&#x9;min: 0, max: 30,&#xA;&#x9;&#x9;minLabel: &#34;None (ideal)&#34;, maxLabel: &#34;Very strong&#34;,&#xA;&#x9;&#x9;update: function(value)&#xA;&#x9;&#x9;{&#xA;&#x9;&#x9;&#x9;currentAttractionStrength = value;&#xA;&#x9;&#x9;&#x9;if (value &lt; 0.1) {&#xA;&#x9;&#x9;&#x9;&#x9;sim.parameters.isOnlyHardSpheres = true;&#xA;&#x9;&#x9;&#x9;&#x9;setInteraction(sim, 0, 0, null);&#xA;&#x9;&#x9;&#x9;} else {&#xA;&#x9;&#x9;&#x9;&#x9;sim.parameters.isOnlyHardSpheres = false;&#xA;&#x9;&#x9;&#x9;&#x9;var ljInteraction = new LennardJonesInteraction();&#xA;&#x9;&#x9;&#x9;&#x9;ljInteraction.strength = value;&#xA;&#x9;&#x9;&#x9;&#x9;setInteraction(sim, 0, 0, ljInteraction);&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;},&#xA;&#x9;});&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h3&gt;Gravity&lt;/h3&gt;&#xA;&lt;script&gt;&#xA;&#x9;createSliderHere({&#xA;&#x9;&#x9;initialValue: 0,&#xA;&#x9;&#x9;min: 0, max: 2,&#xA;&#x9;&#x9;minLabel: &#34;Off&#34;, maxLabel: &#34;Strong&#34;,&#xA;&#x9;&#x9;update: function(value)&#xA;&#x9;&#x9;{&#xA;&#x9;&#x9;&#x9;sim.parameters.gravityAcceleration = value;&#xA;&#x9;&#x9;},&#xA;&#x9;});&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h3&gt;Pressure&lt;/h3&gt;&#xA;&lt;script&gt;&#xA;&#x9;createTimeSeriesHere({&#xA;&#x9;&#x9;timeRange: 100,&#xA;&#x9;&#x9;yMax: 40,&#xA;&#x9;&#x9;update: function(graph) {&#xA;&#x9;&#x9;&#x9;return {time: sim.time, data: [getTotalPressure(sim)]};&#xA;&#x9;&#x9;},&#xA;&#x9;});&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h3&gt;Temperature (measured)&lt;/h3&gt;&#xA;&lt;script&gt;&#xA;&#x9;createTimeSeriesHere({&#xA;&#x9;&#x9;timeRange: 100,&#xA;&#x9;&#x9;yMax: 30,&#xA;&#x9;&#x9;update: function(graph) {&#xA;&#x9;&#x9;&#x9;return {time: sim.time, data: [getTotalTemperature(sim)]};&#xA;&#x9;&#x9;},&#xA;&#x9;});&#xA;&lt;/script&gt;&#xA;&#xA;&lt;p style=&#34;margin-top: 24px; color: var(--text-muted); font-size: 14px;&#34;&gt;Use all the tools, move, create, attract, repel, delete, and all the sliders to explore the full range of gas behavior. See if you can:&lt;/p&gt;</description>
