    <item>
      <title>Correcting the Ideal Gas Law</title>
      <link>//localhost:1313/vanderwaals/1_corrections/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>//localhost:1313/vanderwaals/1_corrections/</guid>
      <description>&lt;div class=&#34;page&#34;&gt;&#xA;&lt;div class=&#34;stepLog twoColumn&#34;&gt;&#xA;&#xA;&lt;script&gt;&#xA;    var idealSim = createSimulation({&#xA;&#x9;&#x9;pixelWidth: 400,&#xA;&#x9;&#x9;pixelHeight: 200,&#xA;        initialize: function(simulation) {&#xA;&#x9;&#x9;&#x9;var p = simulation.parameters;&#xA;&#x9;&#x9;&#x9;p.isOnlyHardSpheres = true;&#xA;&#x9;&#x9;&#x9;p.thermostatDeterministicStrength = 0.5;&#xA;&#x9;&#x9;&#x9;p.thermostatTemperature = 10;&#xA;&#x9;&#x9;&#x9;setBoxWidth(simulation, 60);&#xA;&#x9;&#x9;&#x9;setWallsAlongBorder(simulation);&#xA;&#xA;&#x9;&#x9;&#x9;fillBoxWithParticles(simulation, 80, 10);&#xA;&#x9;&#x9;&#x9;setToolbarAvailableTools(simulation.toolbar, [&#34;move&#34;]);&#xA;        },&#xA;    });&#xA;&#xA;&#x9;var realSim = createSimulation({&#xA;&#x9;&#x9;pixelWidth: 400,&#xA;&#x9;&#x9;pixelHeight: 200,&#xA;        initialize: function(simulation) {&#xA;&#x9;&#x9;&#x9;var p = simulation.parameters;&#xA;&#x9;&#x9;&#x9;p.thermostatDeterministicStrength = 0.5;&#xA;&#x9;&#x9;&#x9;p.thermostatTemperature = 10;&#xA;&#x9;&#x9;&#x9;setBoxWidth(simulation, 60);&#xA;&#x9;&#x9;&#x9;setWallsAlongBorder(simulation);&#xA;&#xA;&#x9;&#x9;&#x9;fillBoxWithParticles(simulation, 80, 10);&#xA;&#xA;&#x9;&#x9;&#x9;var ljInteraction = new LennardJonesInteraction();&#xA;&#x9;&#x9;&#x9;ljInteraction.strength = 5;&#xA;&#x9;&#x9;&#x9;setInteraction(simulation, 0, 0, ljInteraction);&#xA;&#x9;&#x9;&#x9;setToolbarAvailableTools(simulation.toolbar, [&#34;move&#34;]);&#xA;        },&#xA;    });&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h2&gt;The Van der Waals Equation&lt;/h2&gt;&#xA;&#xA;&lt;div class=&#34;equation&#34;&gt;(P + a·n²/V²)(V − nb) = nRT&lt;/div&gt;&#xA;&#xA;&lt;p&gt;This equation makes two corrections to the ideal gas law:&lt;/p&gt;</description>
    </item>
    <item>
      <title>Dalton&#39;s Law</title>
      <link>//localhost:1313/mixtures/1_dalton/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>//localhost:1313/mixtures/1_dalton/</guid>
      <description>&lt;div class=&#34;page&#34;&gt;&#xA;&lt;div class=&#34;stepLog twoColumn&#34;&gt;&#xA;&#xA;&lt;script&gt;&#xA;    var sim = createSimulation({&#xA;        initialize: function(simulation) {&#xA;&#x9;&#x9;&#x9;var p = simulation.parameters;&#xA;&#x9;&#x9;&#x9;p.isOnlyHardSpheres = true;&#xA;&#x9;&#x9;&#x9;setBoxWidth(simulation, 80);&#xA;&#x9;&#x9;&#x9;setWallsAlongBorder(simulation);&#xA;&#xA;&#x9;&#x9;&#x9;// Type A particles (default black)&#xA;&#x9;&#x9;&#x9;var countA = 60;&#xA;&#x9;&#x9;&#x9;for (var i = 0; i &lt; countA; i++) {&#xA;&#x9;&#x9;&#x9;&#x9;var particle = new Particle();&#xA;&#x9;&#x9;&#x9;&#x9;particle.type = 0;&#xA;&#x9;&#x9;&#x9;&#x9;randomDiscInRect(particle.position, particle.radius, simulation.boxBounds);&#xA;&#x9;&#x9;&#x9;&#x9;v2.set(particle.velocity, randomGaussian(), randomGaussian());&#xA;&#x9;&#x9;&#x9;&#x9;v2.scale(particle.velocity, particle.velocity, 2);&#xA;&#x9;&#x9;&#x9;&#x9;addParticle(simulation, particle);&#xA;&#x9;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;&#x9;// Type B particles (red/gray)&#xA;&#x9;&#x9;&#x9;var countB = 40;&#xA;&#x9;&#x9;&#x9;for (var i = 0; i &lt; countB; i++) {&#xA;&#x9;&#x9;&#x9;&#x9;var particle = new Particle();&#xA;&#x9;&#x9;&#x9;&#x9;particle.type = 1;&#xA;&#x9;&#x9;&#x9;&#x9;particle.color = Color.gray;&#xA;&#x9;&#x9;&#x9;&#x9;randomDiscInRect(particle.position, particle.radius, simulation.boxBounds);&#xA;&#x9;&#x9;&#x9;&#x9;v2.set(particle.velocity, randomGaussian(), randomGaussian());&#xA;&#x9;&#x9;&#x9;&#x9;v2.scale(particle.velocity, particle.velocity, 2);&#xA;&#x9;&#x9;&#x9;&#x9;addParticle(simulation, particle);&#xA;&#x9;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;&#x9;setToolbarAvailableTools(simulation.toolbar, [&#34;move&#34;, &#34;create&#34;]);&#xA;        },&#xA;    });&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h2&gt;Dalton&#39;s Law of Partial Pressures&lt;/h2&gt;&#xA;&#xA;&lt;p&gt;What happens when you mix different gases together?&lt;/p&gt;</description>
    </item>
    <item>
      <title>Excluded Volume</title>
      <link>//localhost:1313/real/1_excluded_volume/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>//localhost:1313/real/1_excluded_volume/</guid>
      <description>&lt;div class=&#34;page&#34;&gt;&#xA;&lt;div class=&#34;stepLog twoColumn&#34;&gt;&#xA;&#xA;&lt;script&gt;&#xA;    var sim = createSimulation({&#xA;        initialize: function(simulation) {&#xA;&#x9;&#x9;&#x9;var p = simulation.parameters;&#xA;&#x9;&#x9;&#x9;p.isOnlyHardSpheres = true;&#xA;&#x9;&#x9;&#x9;p.thermostatDeterministicStrength = 0.5;&#xA;&#x9;&#x9;&#x9;p.thermostatTemperature = 10;&#xA;&#x9;&#x9;&#x9;setBoxWidth(simulation, 80);&#xA;&#x9;&#x9;&#x9;setWallsAlongBorder(simulation);&#xA;&#xA;&#x9;&#x9;&#x9;fillBoxWithParticles(simulation, 60, 10);&#xA;&#xA;&#x9;&#x9;&#x9;setToolbarAvailableTools(simulation.toolbar, [&#34;move&#34;, &#34;create&#34;]);&#xA;        },&#xA;    });&#xA;&#xA;    var currentBoxWidth = 80;&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h2&gt;Real Particles Take Up Space&lt;/h2&gt;&#xA;&#xA;&lt;p&gt;The ideal gas law assumes particles are &lt;strong&gt;infinitely small points&lt;/strong&gt;. But real molecules have size!&lt;/p&gt;&#xA;&#xA;&lt;p&gt;Start by adding a &lt;em&gt;lot&lt;/em&gt; more particles with the create tool.&lt;/p&gt;&#xA;&#xA;&lt;script&gt;&#xA;&#x9;cue(function() {&#xA;&#x9;&#x9;return (sim.particles.length &gt; 200);&#xA;&#x9;});&#xA;&#x9;endStep();&#xA;&lt;/script&gt;&#xA;&#xA;&lt;p&gt;Now &lt;strong&gt;shrink the box&lt;/strong&gt; using the slider below.&lt;/p&gt;</description>
    </item>
    <item>
      <title>Free Exploration</title>
      <link>//localhost:1313/playground/1_explore/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>//localhost:1313/playground/1_explore/</guid>
      <description>&lt;div class=&#34;page&#34;&gt;&#xA;&lt;div class=&#34;twoColumn&#34;&gt;&#xA;&#xA;&lt;h2&gt;Playground&lt;/h2&gt;&#xA;&#xA;&lt;p&gt;All the controls, no restrictions. Explore freely!&lt;/p&gt;&#xA;&#xA;&lt;script&gt;&#xA;    var sim = createSimulation({&#xA;        initialize: function(simulation) {&#xA;&#x9;&#x9;&#x9;var p = simulation.parameters;&#xA;&#x9;&#x9;&#x9;p.thermostatDeterministicStrength = 0.5;&#xA;&#x9;&#x9;&#x9;p.thermostatTemperature = 10;&#xA;&#x9;&#x9;&#x9;setBoxWidth(simulation, 80);&#xA;&#x9;&#x9;&#x9;setWallsAlongBorder(simulation);&#xA;&#xA;&#x9;&#x9;&#x9;fillBoxWithParticles(simulation, 80, 10);&#xA;&#xA;&#x9;&#x9;&#x9;setToolbarAvailableTools(simulation.toolbar, [&#34;move&#34;, &#34;create&#34;, &#34;attract&#34;, &#34;repel&#34;, &#34;delete&#34;]);&#xA;        },&#xA;    });&#xA;&#xA;    var currentBoxWidth = 80;&#xA;    var currentAttractionStrength = 0;&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h3&gt;Volume&lt;/h3&gt;&#xA;&lt;script&gt;&#xA;&#x9;createSliderHere({&#xA;&#x9;&#x9;initialValue: 80,&#xA;&#x9;&#x9;min: 15, max: 120,&#xA;&#x9;&#x9;minLabel: &#34;Tiny&#34;, maxLabel: &#34;Huge&#34;,&#xA;&#x9;&#x9;update: function(value)&#xA;&#x9;&#x9;{&#xA;&#x9;&#x9;&#x9;currentBoxWidth = value;&#xA;&#x9;&#x9;&#x9;setBoxWidth(sim, value);&#xA;&#x9;&#x9;&#x9;setWallsAlongBorder(sim);&#xA;&#x9;&#x9;&#x9;// Maintain constant renderer bounds to prevent zooming effect&#xA;&#x9;&#x9;},&#xA;&#x9;});&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h3&gt;Temperature&lt;/h3&gt;&#xA;&lt;script&gt;&#xA;&#x9;createSliderHere({&#xA;&#x9;&#x9;initialValue: 10,&#xA;&#x9;&#x9;min: 0.1, max: 80,&#xA;&#x9;&#x9;minLabel: &#34;Freezing&#34;, maxLabel: &#34;Blazing&#34;,&#xA;&#x9;&#x9;transform: function(x) { return (x * x) },&#xA;&#x9;&#x9;inverseTransform: function(x) { return Math.sqrt(x) },&#xA;&#x9;&#x9;update: function(value)&#xA;&#x9;&#x9;{&#xA;&#x9;&#x9;&#x9;sim.parameters.thermostatTemperature = value;&#xA;&#x9;&#x9;},&#xA;&#x9;});&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h3&gt;Attraction Strength&lt;/h3&gt;&#xA;&lt;script&gt;&#xA;&#x9;createSliderHere({&#xA;&#x9;&#x9;initialValue: 0,&#xA;&#x9;&#x9;min: 0, max: 30,&#xA;&#x9;&#x9;minLabel: &#34;None (ideal)&#34;, maxLabel: &#34;Very strong&#34;,&#xA;&#x9;&#x9;update: function(value)&#xA;&#x9;&#x9;{&#xA;&#x9;&#x9;&#x9;currentAttractionStrength = value;&#xA;&#x9;&#x9;&#x9;if (value &lt; 0.1) {&#xA;&#x9;&#x9;&#x9;&#x9;sim.parameters.isOnlyHardSpheres = true;&#xA;&#x9;&#x9;&#x9;&#x9;setInteraction(sim, 0, 0, null);&#xA;&#x9;&#x9;&#x9;} else {&#xA;&#x9;&#x9;&#x9;&#x9;sim.parameters.isOnlyHardSpheres = false;&#xA;&#x9;&#x9;&#x9;&#x9;var ljInteraction = new LennardJonesInteraction();&#xA;&#x9;&#x9;&#x9;&#x9;ljInteraction.strength = value;&#xA;&#x9;&#x9;&#x9;&#x9;setInteraction(sim, 0, 0, ljInteraction);&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;},&#xA;&#x9;});&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h3&gt;Gravity&lt;/h3&gt;&#xA;&lt;script&gt;&#xA;&#x9;createSliderHere({&#xA;&#x9;&#x9;initialValue: 0,&#xA;&#x9;&#x9;min: 0, max: 2,&#xA;&#x9;&#x9;minLabel: &#34;Off&#34;, maxLabel: &#34;Strong&#34;,&#xA;&#x9;&#x9;update: function(value)&#xA;&#x9;&#x9;{&#xA;&#x9;&#x9;&#x9;sim.parameters.gravityAcceleration = value;&#xA;&#x9;&#x9;},&#xA;&#x9;});&#xA;&lt;/script&gt;&#xA;&#xA;&lt;p style=&#34;margin-top: 24px; color: var(--text-muted); font-size: 14px;&#34;&gt;Use all the tools (move, create, attract, repel, delete) and the sliders to explore gas behavior. See if you can:&lt;/p&gt;</description>
    </item>
    <item>
      <title>Intermolecular Attraction</title>
      <link>//localhost:1313/real/2_attraction/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>//localhost:1313/real/2_attraction/</guid>
      <description>&lt;div class=&#34;page&#34;&gt;&#xA;&lt;div class=&#34;stepLog twoColumn&#34;&gt;&#xA;&#xA;&lt;script&gt;&#xA;    var sim = createSimulation({&#xA;        initialize: function(simulation) {&#xA;&#x9;&#x9;&#x9;var p = simulation.parameters;&#xA;&#x9;&#x9;&#x9;p.thermostatDeterministicStrength = 0.5;&#xA;&#x9;&#x9;&#x9;p.thermostatTemperature = 8;&#xA;&#x9;&#x9;&#x9;setBoxWidth(simulation, 80);&#xA;&#x9;&#x9;&#x9;setWallsAlongBorder(simulation);&#xA;&#xA;&#x9;&#x9;&#x9;fillBoxWithParticles(simulation, 100, 8);&#xA;&#xA;&#x9;&#x9;&#x9;var ljInteraction = new LennardJonesInteraction();&#xA;&#x9;&#x9;&#x9;ljInteraction.strength = 5;&#xA;&#x9;&#x9;&#x9;setInteraction(simulation, 0, 0, ljInteraction);&#xA;&#xA;&#x9;&#x9;&#x9;setToolbarAvailableTools(simulation.toolbar, [&#34;move&#34;, &#34;repel&#34;]);&#xA;        },&#xA;    });&#xA;&#xA;    var attractionStrength = 5;&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h2&gt;Real Particles Attract Each Other&lt;/h2&gt;&#xA;&#xA;&lt;p&gt;The second way real gases differ from ideal: molecules &lt;strong&gt;attract each other&lt;/strong&gt; through van der Waals forces.&lt;/p&gt;&#xA;&#xA;&lt;p&gt;Watch the particles on the right; they tend to &lt;strong&gt;cluster&lt;/strong&gt; slightly. They&#39;re not completely independent like ideal gas particles.&lt;/p&gt;</description>
    </item>
    <item>
      <title>Non-Ideal Mixtures</title>
      <link>//localhost:1313/mixtures/2_nonideal/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>//localhost:1313/mixtures/2_nonideal/</guid>
      <description>&lt;div class=&#34;page&#34;&gt;&#xA;&lt;div class=&#34;stepLog twoColumn&#34;&gt;&#xA;&#xA;&lt;script&gt;&#xA;    var sim = createSimulation({&#xA;        initialize: function(simulation) {&#xA;&#x9;&#x9;&#x9;var p = simulation.parameters;&#xA;&#x9;&#x9;&#x9;p.thermostatDeterministicStrength = 0.3;&#xA;&#x9;&#x9;&#x9;p.thermostatTemperature = 8;&#xA;&#x9;&#x9;&#x9;setBoxWidth(simulation, 80);&#xA;&#x9;&#x9;&#x9;setWallsAlongBorder(simulation);&#xA;&#xA;&#x9;&#x9;&#x9;// Type A particles&#xA;&#x9;&#x9;&#x9;var countA = 50;&#xA;&#x9;&#x9;&#x9;for (var i = 0; i &lt; countA; i++) {&#xA;&#x9;&#x9;&#x9;&#x9;var particle = new Particle();&#xA;&#x9;&#x9;&#x9;&#x9;particle.type = 0;&#xA;&#x9;&#x9;&#x9;&#x9;randomDiscInRect(particle.position, particle.radius, simulation.boxBounds);&#xA;&#x9;&#x9;&#x9;&#x9;v2.set(particle.velocity, randomGaussian(), randomGaussian());&#xA;&#x9;&#x9;&#x9;&#x9;v2.scale(particle.velocity, particle.velocity, 1.5);&#xA;&#x9;&#x9;&#x9;&#x9;addParticle(simulation, particle);&#xA;&#x9;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;&#x9;// Type B particles (red/gray)&#xA;&#x9;&#x9;&#x9;var countB = 50;&#xA;&#x9;&#x9;&#x9;for (var i = 0; i &lt; countB; i++) {&#xA;&#x9;&#x9;&#x9;&#x9;var particle = new Particle();&#xA;&#x9;&#x9;&#x9;&#x9;particle.type = 1;&#xA;&#x9;&#x9;&#x9;&#x9;particle.color = Color.gray;&#xA;&#x9;&#x9;&#x9;&#x9;randomDiscInRect(particle.position, particle.radius, simulation.boxBounds);&#xA;&#x9;&#x9;&#x9;&#x9;v2.set(particle.velocity, randomGaussian(), randomGaussian());&#xA;&#x9;&#x9;&#x9;&#x9;v2.scale(particle.velocity, particle.velocity, 1.5);&#xA;&#x9;&#x9;&#x9;&#x9;addParticle(simulation, particle);&#xA;&#x9;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;&#x9;// Set up interactions&#xA;&#x9;&#x9;&#x9;var ljAA = new LennardJonesInteraction();&#xA;&#x9;&#x9;&#x9;ljAA.strength = 3;&#xA;&#x9;&#x9;&#x9;setInteraction(simulation, 0, 0, ljAA);&#xA;&#xA;&#x9;&#x9;&#x9;var ljBB = new LennardJonesInteraction();&#xA;&#x9;&#x9;&#x9;ljBB.strength = 3;&#xA;&#x9;&#x9;&#x9;setInteraction(simulation, 1, 1, ljBB);&#xA;&#xA;&#x9;&#x9;&#x9;var ljAB = new LennardJonesInteraction();&#xA;&#x9;&#x9;&#x9;ljAB.strength = 3;&#xA;&#x9;&#x9;&#x9;setInteraction(simulation, 0, 1, ljAB);&#xA;&#xA;&#x9;&#x9;&#x9;setToolbarAvailableTools(simulation.toolbar, [&#34;move&#34;, &#34;repel&#34;]);&#xA;        },&#xA;    });&#xA;&#xA;    var crossInteractionStrength = 3;&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h2&gt;Non-Ideal Mixtures&lt;/h2&gt;&#xA;&#xA;&lt;p&gt;Real molecules interact differently depending on what they&#39;re near. A-A interactions might differ from A-B interactions.&lt;/p&gt;</description>
    </item>
    <item>
      <title>Phase Transitions</title>
      <link>//localhost:1313/vanderwaals/2_phase_diagram/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>//localhost:1313/vanderwaals/2_phase_diagram/</guid>
      <description>&lt;div class=&#34;page&#34;&gt;&#xA;&lt;div class=&#34;stepLog twoColumn&#34;&gt;&#xA;&#xA;&lt;script&gt;&#xA;    var sim = createSimulation({&#xA;        initialize: function(simulation) {&#xA;&#x9;&#x9;&#x9;var p = simulation.parameters;&#xA;&#x9;&#x9;&#x9;p.thermostatDeterministicStrength = 1;&#xA;&#x9;&#x9;&#x9;p.thermostatTemperature = 0.5;&#xA;&#x9;&#x9;&#x9;setBoxWidth(simulation, 50);&#xA;&#x9;&#x9;&#x9;setWallsAlongBorder(simulation);&#xA;&#xA;            var particleCount = 37;&#xA;            for (var particleIndex = 0; particleIndex &lt; particleCount; particleIndex++) {&#xA;                var particle = new Particle();&#xA;                hexagonalLatticePosition(particle.position, particleIndex, 2);&#xA;                addParticle(simulation, particle);&#xA;            }&#xA;&#xA;            var displacement = v2.alloc();&#xA;            var displacementMagnitude = 0.01;&#xA;            for (var particleIndex = 0; particleIndex &lt; simulation.particles.length; particleIndex++) {&#xA;                var particle = simulation.particles[particleIndex];&#xA;                v2.set(displacement, randomGaussian(), randomGaussian());&#xA;                v2.scaleAndAdd(particle.position, particle.position, &#xA;                    displacement, displacementMagnitude);&#xA;            }&#xA;            v2.free(displacement);&#xA;&#xA;            var ljInteraction = new LennardJonesInteraction();&#xA;            ljInteraction.strength = 10;&#xA;            setInteraction(simulation, 0, 0, ljInteraction);&#xA;&#xA;            setToolbarAvailableTools(simulation.toolbar, [&#34;move&#34;]);&#xA;        }&#xA;    });&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h2&gt;Phase Transitions&lt;/h2&gt;&#xA;&#xA;&lt;p&gt;The van der Waals equation predicts something the ideal gas law cannot: &lt;strong&gt;phase transitions&lt;/strong&gt;.&lt;/p&gt;</description>
    </item>
    <item>
      <title>Pressure &amp; Temperature</title>
      <link>//localhost:1313/ideal/2_pressure_temperature/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>//localhost:1313/ideal/2_pressure_temperature/</guid>
      <description>&lt;div class=&#34;page&#34;&gt;&#xA;&lt;div class=&#34;stepLog twoColumn&#34;&gt;&#xA;&#xA;&lt;script&gt;&#xA;    var sim = createSimulation({&#xA;        initialize: function(simulation) {&#xA;&#x9;&#x9;&#x9;var p = simulation.parameters;&#xA;&#x9;&#x9;&#x9;p.isOnlyHardSpheres = true;&#xA;&#x9;&#x9;&#x9;p.thermostatDeterministicStrength = 1;&#xA;&#x9;&#x9;&#x9;p.thermostatTemperature = 5;&#xA;&#x9;&#x9;&#x9;setBoxWidth(simulation, 80);&#xA;&#x9;&#x9;&#x9;setWallsAlongBorder(simulation);&#xA;&#xA;&#x9;&#x9;&#x9;fillBoxWithParticles(simulation, 120, 5);&#xA;&#xA;&#x9;&#x9;&#x9;setToolbarAvailableTools(simulation.toolbar, [&#34;move&#34;]);&#xA;        },&#xA;    });&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h2&gt;Pressure &amp; Temperature: Gay-Lussac&#39;s Law&lt;/h2&gt;&#xA;&#xA;&lt;p&gt;Now let&#39;s keep the volume fixed and change the &lt;strong&gt;temperature&lt;/strong&gt; instead.&lt;/p&gt;&#xA;&#xA;&lt;p&gt;Temperature controls how fast the particles move. Use the slider below to crank up the heat.&lt;/p&gt;&#xA;&#xA;&lt;script&gt;&#xA;&#x9;createSliderHere({&#xA;&#x9;&#x9;initialValue: 5,&#xA;&#x9;&#x9;min: 1, max: 50,&#xA;&#x9;&#x9;minLabel: &#34;Cold&#34;, maxLabel: &#34;Hot&#34;,&#xA;&#x9;&#x9;transform: function(x) { return (x * x) },&#xA;&#x9;&#x9;inverseTransform: function(x) { return Math.sqrt(x) },&#xA;&#x9;&#x9;update: function(value)&#xA;&#x9;&#x9;{&#xA;&#x9;&#x9;&#x9;sim.parameters.thermostatTemperature = value;&#xA;&#x9;&#x9;},&#xA;&#x9;});&#xA;&lt;/script&gt;&#xA;&#xA;&lt;p&gt;Increase the temperature and watch the particles.&lt;/p&gt;</description>
    </item>
    <item>
      <title>Pressure &amp; Volume</title>
      <link>//localhost:1313/ideal/1_pressure_volume/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>//localhost:1313/ideal/1_pressure_volume/</guid>
      <description>&lt;div class=&#34;page&#34;&gt;&#xA;&lt;div class=&#34;stepLog twoColumn&#34;&gt;&#xA;&#xA;&lt;script&gt;&#xA;    var sim = createSimulation({&#xA;        initialize: function(simulation) {&#xA;&#x9;&#x9;&#x9;var p = simulation.parameters;&#xA;&#x9;&#x9;&#x9;p.isOnlyHardSpheres = true;&#xA;&#x9;&#x9;&#x9;setBoxWidth(simulation, 100);&#xA;&#x9;&#x9;&#x9;setWallsAlongBorder(simulation);&#xA;&#xA;&#x9;&#x9;&#x9;fillBoxWithParticles(simulation, 150, 8);&#xA;&#xA;&#x9;&#x9;&#x9;setToolbarAvailableTools(simulation.toolbar, [&#34;move&#34;]);&#xA;        },&#xA;    });&#xA;&#xA;    var currentBoxWidth = 100;&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h2&gt;Pressure &amp; Volume: Boyle&#39;s Law&lt;/h2&gt;&#xA;&#xA;&lt;p&gt;What happens when you &lt;strong&gt;squeeze&lt;/strong&gt; a gas into a smaller space?&lt;/p&gt;&#xA;&#xA;&lt;p&gt;Use the slider below to change the &lt;strong&gt;volume&lt;/strong&gt; (width) of the box.&lt;/p&gt;&#xA;&#xA;&lt;script&gt;&#xA;&#x9;createSliderHere({&#xA;&#x9;&#x9;initialValue: 100,&#xA;&#x9;&#x9;min: 30, max: 100,&#xA;&#x9;&#x9;minLabel: &#34;Small&#34;, maxLabel: &#34;Large&#34;,&#xA;&#x9;&#x9;update: function(value)&#xA;&#x9;&#x9;{&#xA;&#x9;&#x9;&#x9;currentBoxWidth = value;&#xA;&#x9;&#x9;&#x9;setBoxWidth(sim, value);&#xA;&#x9;&#x9;&#x9;setWallsAlongBorder(sim);&#xA;&#x9;&#x9;&#x9;&#xA;&#x9;&#x9;&#x9;// We DO NOT update the renderer bounds here. &#xA;&#x9;&#x9;&#x9;// Keeping the renderer bounds at the original max size ensures the particles &#xA;&#x9;&#x9;&#x9;// maintain a constant visual size while the box itself appears to shrink.&#xA;&#x9;&#x9;},&#xA;&#x9;});&#xA;&lt;/script&gt;&#xA;&#xA;&lt;p&gt;Shrink the box and watch what happens.&lt;/p&gt;</description>
    </item>
    <item>
      <title>Pressure is Momentum</title>
      <link>//localhost:1313/kinetic/2_pressure_momentum/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>//localhost:1313/kinetic/2_pressure_momentum/</guid>
      <description>&lt;div class=&#34;page&#34;&gt;&#xA;&lt;div class=&#34;stepLog twoColumn&#34;&gt;&#xA;&#xA;&lt;script&gt;&#xA;    var wallDetectorSim = createSimulation({&#xA;        initialize: function(simulation) {&#xA;            var p = simulation.parameters;&#xA;&#x9;&#x9;&#x9;p.isOnlyHardSpheres = true;&#xA;            p.dragStrength = 2;&#xA;&#x9;&#x9;&#x9;setBoxWidth(simulation, 40);&#xA;&#x9;&#x9;&#x9;setWallsAlongBorder(simulation);&#xA;&#xA;            var particle = new Particle();&#xA;&#x9;&#x9;&#x9;particle.radius = 2;&#xA;            addParticle(simulation, particle);&#xA;&#xA;&#x9;&#x9;&#x9;setToolbarAvailableTools(simulation.toolbar, [&#34;move&#34;]);&#xA;        },&#xA;    });&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h2&gt;Pressure IS Momentum Transfer&lt;/h2&gt;&#xA;&#xA;&lt;p&gt;Let&#39;s zoom in on what pressure really means at the particle level.&lt;/p&gt;&#xA;&#xA;&lt;p&gt;Here&#39;s a single, large particle. Throw it at a wall!&lt;/p&gt;&#xA;&#xA;&lt;script&gt;&#xA;&#x9;cue(function() {&#xA;&#x9;&#x9;var pressure = getTotalPressure(wallDetectorSim);&#xA;&#x9;&#x9;return (pressure &gt; 1);&#xA;&#x9;});&#xA;&#x9;endStep();&#xA;&lt;/script&gt;&#xA;&#xA;&lt;p&gt;See that spike in the graph on the right? That&#39;s the &lt;strong&gt;momentum transfer&lt;/strong&gt;. The particle hits the wall, reverses direction, and pushes the wall outward in the process.&lt;/p&gt;</description>
    </item>
    <item>
      <title>PV = nRT</title>
      <link>//localhost:1313/ideal/3_pvnrt/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>//localhost:1313/ideal/3_pvnrt/</guid>
      <description>&lt;div class=&#34;page&#34;&gt;&#xA;&lt;div class=&#34;stepLog twoColumn&#34;&gt;&#xA;&#xA;&lt;script&gt;&#xA;    var sim = createSimulation({&#xA;        initialize: function(simulation) {&#xA;&#x9;&#x9;&#x9;var p = simulation.parameters;&#xA;&#x9;&#x9;&#x9;p.isOnlyHardSpheres = true;&#xA;&#x9;&#x9;&#x9;p.thermostatDeterministicStrength = 1;&#xA;&#x9;&#x9;&#x9;p.thermostatTemperature = 10;&#xA;&#x9;&#x9;&#x9;setBoxWidth(simulation, 80);&#xA;&#x9;&#x9;&#x9;setWallsAlongBorder(simulation);&#xA;&#xA;&#x9;&#x9;&#x9;fillBoxWithParticles(simulation, 100, 10);&#xA;&#xA;&#x9;&#x9;&#x9;setToolbarAvailableTools(simulation.toolbar, [&#34;move&#34;, &#34;create&#34;]);&#xA;        },&#xA;    });&#xA;&#xA;    var currentBoxWidth = 80;&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h2&gt;Putting It Together: PV = nRT&lt;/h2&gt;&#xA;&#xA;&lt;div class=&#34;equation&#34;&gt;PV = nRT&lt;/div&gt;&#xA;&#xA;&lt;p&gt;This is the &lt;strong&gt;ideal gas law&lt;/strong&gt;. It combines everything we&#39;ve seen:&lt;/p&gt;&#xA;&lt;ul&gt;&#xA;  &lt;li&gt;&lt;strong&gt;P&lt;/strong&gt;, pressure (how hard particles push on walls)&lt;/li&gt;&#xA;  &lt;li&gt;&lt;strong&gt;V&lt;/strong&gt;, volume (how much space they have)&lt;/li&gt;&#xA;  &lt;li&gt;&lt;strong&gt;n&lt;/strong&gt;, amount of gas (number of moles)&lt;/li&gt;&#xA;  &lt;li&gt;&lt;strong&gt;R&lt;/strong&gt;, a universal constant&lt;/li&gt;&#xA;  &lt;li&gt;&lt;strong&gt;T&lt;/strong&gt;, temperature (how fast they move)&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&#xA;&lt;p&gt;Use both sliders to change volume and temperature.&lt;/p&gt;</description>
    </item>
    <item>
      <title>Temperature is Motion</title>
      <link>//localhost:1313/kinetic/1_temperature_motion/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>//localhost:1313/kinetic/1_temperature_motion/</guid>
      <description>&lt;div class=&#34;page&#34;&gt;&#xA;&lt;div class=&#34;stepLog twoColumn&#34;&gt;&#xA;&#xA;&lt;script&gt;&#xA;    var sim = createSimulation({&#xA;        initialize: function(simulation) {&#xA;&#x9;&#x9;&#x9;var p = simulation.parameters;&#xA;&#x9;&#x9;&#x9;p.isOnlyHardSpheres = true;&#xA;&#x9;&#x9;&#x9;p.thermostatDeterministicStrength = 1;&#xA;&#x9;&#x9;&#x9;p.thermostatTemperature = 5;&#xA;&#x9;&#x9;&#x9;setBoxWidth(simulation, 80);&#xA;&#x9;&#x9;&#x9;setWallsAlongBorder(simulation);&#xA;&#xA;&#x9;&#x9;&#x9;fillBoxWithParticles(simulation, 80, 5);&#xA;&#xA;&#x9;&#x9;&#x9;setToolbarAvailableTools(simulation.toolbar, [&#34;move&#34;]);&#xA;        },&#xA;    });&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h2&gt;Temperature IS Motion&lt;/h2&gt;&#xA;&#xA;&lt;p&gt;Temperature isn&#39;t some mysterious abstract quantity. It&#39;s simply a measure of &lt;strong&gt;how fast the particles are moving&lt;/strong&gt;.&lt;/p&gt;&#xA;&#xA;&lt;div class=&#34;equation&#34;&gt;T = ⅔ × (E&lt;sub&gt;avg&lt;/sub&gt; / k&lt;sub&gt;B&lt;/sub&gt;)&lt;/div&gt;&#xA;&#xA;&lt;p&gt;Each particle has kinetic energy (½mv²). Temperature is the &lt;strong&gt;average&lt;/strong&gt; energy of all particles, adjusted by two constants:&lt;/p&gt;</description>
    </item>
    <item>
      <title>Welcome</title>
      <link>//localhost:1313/intro/1_welcome/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>//localhost:1313/intro/1_welcome/</guid>
      <description>&lt;div class=&#34;page&#34;&gt;&#xA;&lt;div class=&#34;stepLog twoColumn&#34;&gt;&#xA;&#xA;&lt;script&gt;&#xA;    var sim = createSimulation({&#xA;        initialize: function(simulation) {&#xA;&#x9;&#x9;&#x9;var p = simulation.parameters;&#xA;&#x9;&#x9;&#x9;p.isOnlyHardSpheres = true;&#xA;&#x9;&#x9;&#x9;setBoxWidth(simulation, 60);&#xA;&#x9;&#x9;&#x9;setWallsAlongBorder(simulation);&#xA;&#xA;&#x9;&#x9;&#x9;fillBoxWithParticles(simulation, 60, 2);&#xA;&#xA;&#x9;&#x9;&#x9;setToolbarAvailableTools(simulation.toolbar, [&#34;move&#34;, &#34;create&#34;, &#34;attract&#34;]);&#xA;        },&#xA;    });&#xA;&lt;/script&gt;&#xA;&#xA;&lt;p&gt;Welcome! Throughout this explainer, you&#39;ll interact with &lt;strong&gt;particle simulations&lt;/strong&gt; like the one on the right.&lt;/p&gt;&#xA;&#xA;&lt;p&gt;These simulations run in real time and respond to your input. Try &lt;strong&gt;clicking and dragging&lt;/strong&gt; a particle to throw it around!&lt;/p&gt;&#xA;&#xA;&lt;script&gt;&#xA;&#x9;cue(function() {&#xA;&#x9;&#x9;return (sim.mouse.mode === MouseMode.move);&#xA;&#x9;});&#xA;&#x9;endStep();&#xA;&lt;/script&gt;&#xA;&#xA;&lt;p&gt;Nice! You can also &lt;strong&gt;switch tools&lt;/strong&gt; using the dropdown in the bottom-right corner of the simulation.&lt;/p&gt;</description>
    </item>
    <item>
      <title>What is a Gas?</title>
      <link>//localhost:1313/gas/1_what_is_gas/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>//localhost:1313/gas/1_what_is_gas/</guid>
      <description>&lt;div class=&#34;page&#34;&gt;&#xA;&lt;div class=&#34;stepLog twoColumn&#34;&gt;&#xA;&#xA;&lt;script&gt;&#xA;    var sim = createSimulation({&#xA;        initialize: function(simulation) {&#xA;&#x9;&#x9;&#x9;var p = simulation.parameters;&#xA;&#x9;&#x9;&#x9;p.isOnlyHardSpheres = true;&#xA;&#x9;&#x9;&#x9;setBoxWidth(simulation, 80);&#xA;&#x9;&#x9;&#x9;setWallsAlongBorder(simulation);&#xA;&#xA;&#x9;&#x9;&#x9;fillBoxWithParticles(simulation, 100, 4);&#xA;&#xA;&#x9;&#x9;&#x9;setToolbarAvailableTools(simulation.toolbar, [&#34;move&#34;, &#34;create&#34;]);&#xA;        },&#xA;    });&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h2&gt;Gas Basics: Particles in Motion&lt;/h2&gt;&#xA;&#xA;&lt;p&gt;A &lt;strong&gt;gas&lt;/strong&gt; is a collection of tiny particles, atoms or molecules, moving randomly in all directions.&lt;/p&gt;&#xA;&#xA;&lt;p&gt;They bounce off each other and off the walls of their container. Between collisions, they travel in straight lines.&lt;/p&gt;&#xA;&#xA;&lt;p&gt;Watch the particles on the right. Notice how they &lt;strong&gt;spread out to fill the entire box&lt;/strong&gt;.&lt;/p&gt;</description>
    </item>
