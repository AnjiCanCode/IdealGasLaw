    <item>
      <title>Correcting the Ideal Gas Law</title>
      <link>//localhost:1313/vanderwaals/1_corrections.html</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>//localhost:1313/vanderwaals/1_corrections.html</guid>
      <description>&lt;div class=&#34;page&#34;&gt;&#xA;&lt;div class=&#34;stepLog twoColumn&#34;&gt;&#xA;&#xA;&lt;h2&gt;The Van der Waals Equation&lt;/h2&gt;&#xA;&#xA;&lt;div class=&#34;equation&#34;&gt;(P + a·n²/V²)(V − nb) = nRT&lt;/div&gt;&#xA;&#xA;&lt;p&gt;This equation makes two corrections to the ideal gas law:&lt;/p&gt;&#xA;&#xA;&lt;ul&gt;&#xA;  &lt;li&gt;&lt;strong&gt;+ a·n²/V²&lt;/strong&gt; — corrects for intermolecular &lt;strong&gt;attraction&lt;/strong&gt; reducing the measured pressure&lt;/li&gt;&#xA;  &lt;li&gt;&lt;strong&gt;− nb&lt;/strong&gt; — corrects for the &lt;strong&gt;excluded volume&lt;/strong&gt; of the molecules themselves&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&#xA;&lt;p&gt;Let&#39;s compare. On the right are &lt;strong&gt;two simulations running side by side&lt;/strong&gt;.&lt;/p&gt;&#xA;&#xA;&lt;script&gt;&#xA;    var idealSim = createSimulation({&#xA;&#x9;&#x9;pixelWidth: 400,&#xA;&#x9;&#x9;pixelHeight: 200,&#xA;        initialize: function(simulation) {&#xA;&#x9;&#x9;&#x9;var p = simulation.parameters;&#xA;&#x9;&#x9;&#x9;p.isOnlyHardSpheres = true;&#xA;&#x9;&#x9;&#x9;p.thermostatDeterministicStrength = 0.5;&#xA;&#x9;&#x9;&#x9;p.thermostatTemperature = 10;&#xA;&#x9;&#x9;&#x9;setBoxWidth(simulation, 60);&#xA;&#xA;&#x9;&#x9;&#x9;var particleCount = 80;&#xA;&#x9;&#x9;&#x9;for (var i = 0; i &lt; particleCount; i++) {&#xA;&#x9;&#x9;&#x9;&#x9;var particle = new Particle();&#xA;&#x9;&#x9;&#x9;&#x9;randomDiscInRect(particle.position, particle.radius, simulation.boxBounds);&#xA;&#x9;&#x9;&#x9;&#x9;v2.set(particle.velocity, randomGaussian(), randomGaussian());&#xA;&#x9;&#x9;&#x9;&#x9;v2.scale(particle.velocity, particle.velocity, 6);&#xA;&#x9;&#x9;&#x9;&#x9;addParticle(simulation, particle);&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;setToolbarAvailableTools(simulation.toolbar, [&#34;move&#34;]);&#xA;        },&#xA;    });&#xA;&#xA;&#x9;var realSim = createSimulation({&#xA;&#x9;&#x9;pixelWidth: 400,&#xA;&#x9;&#x9;pixelHeight: 200,&#xA;        initialize: function(simulation) {&#xA;&#x9;&#x9;&#x9;var p = simulation.parameters;&#xA;&#x9;&#x9;&#x9;p.thermostatDeterministicStrength = 0.5;&#xA;&#x9;&#x9;&#x9;p.thermostatTemperature = 10;&#xA;&#x9;&#x9;&#x9;setBoxWidth(simulation, 60);&#xA;&#xA;&#x9;&#x9;&#x9;var particleCount = 80;&#xA;&#x9;&#x9;&#x9;var particles = [];&#xA;&#x9;&#x9;&#x9;for (var i = 0; i &lt; particleCount; i++) {&#xA;&#x9;&#x9;&#x9;&#x9;var particle = new Particle();&#xA;&#x9;&#x9;&#x9;&#x9;particles.push(particle);&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;addParticlesRandomlyAround(simulation, particles, v2(0, 0));&#xA;&#xA;&#x9;&#x9;&#x9;var ljInteraction = new LennardJonesInteraction();&#xA;&#x9;&#x9;&#x9;ljInteraction.strength = 5;&#xA;&#x9;&#x9;&#x9;setInteraction(simulation, 0, 0, ljInteraction);&#xA;&#x9;&#x9;&#x9;setToolbarAvailableTools(simulation.toolbar, [&#34;move&#34;]);&#xA;        },&#xA;    });&#xA;&lt;/script&gt;&#xA;&#xA;&lt;p&gt;&lt;strong&gt;Top:&lt;/strong&gt; Ideal gas (no attraction, point particles)&lt;br&gt;&#xA;&lt;strong&gt;Bottom:&lt;/strong&gt; Real gas (attraction + finite size)&lt;/p&gt;</description>
    </item>
    <item>
      <title>Dalton&#39;s Law</title>
      <link>//localhost:1313/mixtures/1_dalton.html</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>//localhost:1313/mixtures/1_dalton.html</guid>
      <description>&lt;div class=&#34;page&#34;&gt;&#xA;&lt;div class=&#34;stepLog twoColumn&#34;&gt;&#xA;&#xA;&lt;script&gt;&#xA;    var sim = createSimulation({&#xA;        initialize: function(simulation) {&#xA;&#x9;&#x9;&#x9;var p = simulation.parameters;&#xA;&#x9;&#x9;&#x9;p.isOnlyHardSpheres = true;&#xA;&#x9;&#x9;&#x9;setBoxWidth(simulation, 80);&#xA;&#xA;&#x9;&#x9;&#x9;// Type A particles (default black)&#xA;&#x9;&#x9;&#x9;var countA = 60;&#xA;&#x9;&#x9;&#x9;for (var i = 0; i &lt; countA; i++) {&#xA;&#x9;&#x9;&#x9;&#x9;var particle = new Particle();&#xA;&#x9;&#x9;&#x9;&#x9;particle.type = 0;&#xA;&#x9;&#x9;&#x9;&#x9;randomDiscInRect(particle.position, particle.radius, simulation.boxBounds);&#xA;&#x9;&#x9;&#x9;&#x9;v2.set(particle.velocity, randomGaussian(), randomGaussian());&#xA;&#x9;&#x9;&#x9;&#x9;v2.scale(particle.velocity, particle.velocity, 8);&#xA;&#x9;&#x9;&#x9;&#x9;addParticle(simulation, particle);&#xA;&#x9;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;&#x9;// Type B particles (red)&#xA;&#x9;&#x9;&#x9;var countB = 40;&#xA;&#x9;&#x9;&#x9;for (var i = 0; i &lt; countB; i++) {&#xA;&#x9;&#x9;&#x9;&#x9;var particle = new Particle();&#xA;&#x9;&#x9;&#x9;&#x9;particle.type = 1;&#xA;&#x9;&#x9;&#x9;&#x9;particle.color = Color.gray;&#xA;&#x9;&#x9;&#x9;&#x9;randomDiscInRect(particle.position, particle.radius, simulation.boxBounds);&#xA;&#x9;&#x9;&#x9;&#x9;v2.set(particle.velocity, randomGaussian(), randomGaussian());&#xA;&#x9;&#x9;&#x9;&#x9;v2.scale(particle.velocity, particle.velocity, 8);&#xA;&#x9;&#x9;&#x9;&#x9;addParticle(simulation, particle);&#xA;&#x9;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;&#x9;setToolbarAvailableTools(simulation.toolbar, [&#34;move&#34;, &#34;create&#34;]);&#xA;        },&#xA;    });&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h2&gt;Dalton&#39;s Law of Partial Pressures&lt;/h2&gt;&#xA;&#xA;&lt;p&gt;What happens when you mix different gases together?&lt;/p&gt;</description>
    </item>
    <item>
      <title>Excluded Volume</title>
      <link>//localhost:1313/real/1_excluded_volume.html</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>//localhost:1313/real/1_excluded_volume.html</guid>
      <description>&lt;div class=&#34;page&#34;&gt;&#xA;&lt;div class=&#34;stepLog twoColumn&#34;&gt;&#xA;&#xA;&lt;script&gt;&#xA;    var sim = createSimulation({&#xA;        initialize: function(simulation) {&#xA;&#x9;&#x9;&#x9;var p = simulation.parameters;&#xA;&#x9;&#x9;&#x9;p.isOnlyHardSpheres = true;&#xA;&#x9;&#x9;&#x9;p.thermostatDeterministicStrength = 0.5;&#xA;&#x9;&#x9;&#x9;p.thermostatTemperature = 10;&#xA;&#x9;&#x9;&#x9;setBoxWidth(simulation, 80);&#xA;&#xA;&#x9;&#x9;&#x9;var particleCount = 60;&#xA;&#x9;&#x9;&#x9;for (var i = 0; i &lt; particleCount; i++) {&#xA;&#x9;&#x9;&#x9;&#x9;var particle = new Particle();&#xA;&#x9;&#x9;&#x9;&#x9;randomDiscInRect(particle.position, particle.radius, simulation.boxBounds);&#xA;&#x9;&#x9;&#x9;&#x9;v2.set(particle.velocity, randomGaussian(), randomGaussian());&#xA;&#x9;&#x9;&#x9;&#x9;v2.scale(particle.velocity, particle.velocity, 6);&#xA;&#x9;&#x9;&#x9;&#x9;addParticle(simulation, particle);&#xA;&#x9;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;&#x9;setToolbarAvailableTools(simulation.toolbar, [&#34;move&#34;, &#34;create&#34;]);&#xA;        },&#xA;    });&#xA;&#xA;    var currentBoxWidth = 80;&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h2&gt;Real Particles Take Up Space&lt;/h2&gt;&#xA;&#xA;&lt;p&gt;The ideal gas law assumes particles are &lt;strong&gt;infinitely small points&lt;/strong&gt;. But real molecules have size!&lt;/p&gt;</description>
    </item>
    <item>
      <title>Free Exploration</title>
      <link>//localhost:1313/playground/1_explore.html</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>//localhost:1313/playground/1_explore.html</guid>
      <description>&lt;div class=&#34;page&#34;&gt;&#xA;&lt;div class=&#34;twoColumn&#34;&gt;&#xA;&#xA;&lt;h2&gt;Playground&lt;/h2&gt;&#xA;&#xA;&lt;p&gt;All the controls, no restrictions. Explore freely!&lt;/p&gt;&#xA;&#xA;&lt;script&gt;&#xA;    var sim = createSimulation({&#xA;        initialize: function(simulation) {&#xA;&#x9;&#x9;&#x9;var p = simulation.parameters;&#xA;&#x9;&#x9;&#x9;p.thermostatDeterministicStrength = 0.5;&#xA;&#x9;&#x9;&#x9;p.thermostatTemperature = 10;&#xA;&#x9;&#x9;&#x9;setBoxWidth(simulation, 80);&#xA;&#xA;&#x9;&#x9;&#x9;var particleCount = 80;&#xA;&#x9;&#x9;&#x9;for (var i = 0; i &lt; particleCount; i++) {&#xA;&#x9;&#x9;&#x9;&#x9;var particle = new Particle();&#xA;&#x9;&#x9;&#x9;&#x9;randomDiscInRect(particle.position, particle.radius, simulation.boxBounds);&#xA;&#x9;&#x9;&#x9;&#x9;v2.set(particle.velocity, randomGaussian(), randomGaussian());&#xA;&#x9;&#x9;&#x9;&#x9;v2.scale(particle.velocity, particle.velocity, 6);&#xA;&#x9;&#x9;&#x9;&#x9;addParticle(simulation, particle);&#xA;&#x9;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;&#x9;setToolbarAvailableTools(simulation.toolbar, [&#34;move&#34;, &#34;create&#34;, &#34;attract&#34;, &#34;repel&#34;, &#34;delete&#34;]);&#xA;        },&#xA;    });&#xA;&#xA;    var currentBoxWidth = 80;&#xA;    var currentAttractionStrength = 0;&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h3&gt;Volume&lt;/h3&gt;&#xA;&lt;script&gt;&#xA;&#x9;createSliderHere({&#xA;&#x9;&#x9;initialValue: 80,&#xA;&#x9;&#x9;min: 15, max: 120,&#xA;&#x9;&#x9;minLabel: &#34;Tiny&#34;, maxLabel: &#34;Huge&#34;,&#xA;&#x9;&#x9;update: function(value)&#xA;&#x9;&#x9;{&#xA;&#x9;&#x9;&#x9;currentBoxWidth = value;&#xA;&#x9;&#x9;&#x9;setBoxWidth(sim, value);&#xA;&#x9;&#x9;&#x9;setWallsAlongBorder(sim);&#xA;&#x9;&#x9;},&#xA;&#x9;});&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h3&gt;Temperature&lt;/h3&gt;&#xA;&lt;script&gt;&#xA;&#x9;createSliderHere({&#xA;&#x9;&#x9;initialValue: 10,&#xA;&#x9;&#x9;min: 0.1, max: 80,&#xA;&#x9;&#x9;minLabel: &#34;Freezing&#34;, maxLabel: &#34;Blazing&#34;,&#xA;&#x9;&#x9;transform: function(x) { return (x * x) },&#xA;&#x9;&#x9;inverseTransform: function(x) { return Math.sqrt(x) },&#xA;&#x9;&#x9;update: function(value)&#xA;&#x9;&#x9;{&#xA;&#x9;&#x9;&#x9;sim.parameters.thermostatTemperature = value;&#xA;&#x9;&#x9;},&#xA;&#x9;});&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h3&gt;Attraction Strength&lt;/h3&gt;&#xA;&lt;script&gt;&#xA;&#x9;createSliderHere({&#xA;&#x9;&#x9;initialValue: 0,&#xA;&#x9;&#x9;min: 0, max: 30,&#xA;&#x9;&#x9;minLabel: &#34;None (ideal)&#34;, maxLabel: &#34;Very strong&#34;,&#xA;&#x9;&#x9;update: function(value)&#xA;&#x9;&#x9;{&#xA;&#x9;&#x9;&#x9;currentAttractionStrength = value;&#xA;&#x9;&#x9;&#x9;if (value &lt; 0.1) {&#xA;&#x9;&#x9;&#x9;&#x9;sim.parameters.isOnlyHardSpheres = true;&#xA;&#x9;&#x9;&#x9;&#x9;setInteraction(sim, 0, 0, null);&#xA;&#x9;&#x9;&#x9;} else {&#xA;&#x9;&#x9;&#x9;&#x9;sim.parameters.isOnlyHardSpheres = false;&#xA;&#x9;&#x9;&#x9;&#x9;var ljInteraction = new LennardJonesInteraction();&#xA;&#x9;&#x9;&#x9;&#x9;ljInteraction.strength = value;&#xA;&#x9;&#x9;&#x9;&#x9;setInteraction(sim, 0, 0, ljInteraction);&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;},&#xA;&#x9;});&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h3&gt;Gravity&lt;/h3&gt;&#xA;&lt;script&gt;&#xA;&#x9;createSliderHere({&#xA;&#x9;&#x9;initialValue: 0,&#xA;&#x9;&#x9;min: 0, max: 2,&#xA;&#x9;&#x9;minLabel: &#34;Off&#34;, maxLabel: &#34;Strong&#34;,&#xA;&#x9;&#x9;update: function(value)&#xA;&#x9;&#x9;{&#xA;&#x9;&#x9;&#x9;sim.parameters.gravityAcceleration = value;&#xA;&#x9;&#x9;},&#xA;&#x9;});&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h3&gt;Pressure&lt;/h3&gt;&#xA;&lt;script&gt;&#xA;&#x9;createTimeSeriesHere({&#xA;&#x9;&#x9;timeRange: 100,&#xA;&#x9;&#x9;yMax: 40,&#xA;&#x9;&#x9;update: function(graph) {&#xA;&#x9;&#x9;&#x9;return {time: sim.time, data: [getTotalPressure(sim)]};&#xA;&#x9;&#x9;},&#xA;&#x9;});&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h3&gt;Temperature (measured)&lt;/h3&gt;&#xA;&lt;script&gt;&#xA;&#x9;createTimeSeriesHere({&#xA;&#x9;&#x9;timeRange: 100,&#xA;&#x9;&#x9;yMax: 30,&#xA;&#x9;&#x9;update: function(graph) {&#xA;&#x9;&#x9;&#x9;return {time: sim.time, data: [getTotalTemperature(sim)]};&#xA;&#x9;&#x9;},&#xA;&#x9;});&#xA;&lt;/script&gt;&#xA;&#xA;&lt;p style=&#34;margin-top: 24px; color: var(--text-muted); font-size: 14px;&#34;&gt;Use all the tools — move, create, attract, repel, delete — and all the sliders to explore the full range of gas behavior. See if you can:&lt;/p&gt;</description>
    </item>
    <item>
      <title>Intermolecular Attraction</title>
      <link>//localhost:1313/real/2_attraction.html</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>//localhost:1313/real/2_attraction.html</guid>
      <description>&lt;div class=&#34;page&#34;&gt;&#xA;&lt;div class=&#34;stepLog twoColumn&#34;&gt;&#xA;&#xA;&lt;script&gt;&#xA;    var sim = createSimulation({&#xA;        initialize: function(simulation) {&#xA;&#x9;&#x9;&#x9;var p = simulation.parameters;&#xA;&#x9;&#x9;&#x9;p.thermostatDeterministicStrength = 0.5;&#xA;&#x9;&#x9;&#x9;p.thermostatTemperature = 8;&#xA;&#x9;&#x9;&#x9;setBoxWidth(simulation, 80);&#xA;&#xA;&#x9;&#x9;&#x9;var particleCount = 100;&#xA;&#x9;&#x9;&#x9;var particles = [];&#xA;&#x9;&#x9;&#x9;for (var i = 0; i &lt; particleCount; i++) {&#xA;&#x9;&#x9;&#x9;&#x9;var particle = new Particle();&#xA;&#x9;&#x9;&#x9;&#x9;particles.push(particle);&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;addParticlesRandomlyAround(simulation, particles, v2(0, 0));&#xA;&#xA;&#x9;&#x9;&#x9;var ljInteraction = new LennardJonesInteraction();&#xA;&#x9;&#x9;&#x9;ljInteraction.strength = 5;&#xA;&#x9;&#x9;&#x9;setInteraction(simulation, 0, 0, ljInteraction);&#xA;&#xA;&#x9;&#x9;&#x9;setToolbarAvailableTools(simulation.toolbar, [&#34;move&#34;, &#34;repel&#34;]);&#xA;        },&#xA;    });&#xA;&#xA;    var attractionStrength = 5;&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h2&gt;Real Particles Attract Each Other&lt;/h2&gt;&#xA;&#xA;&lt;p&gt;The second way real gases differ from ideal: molecules &lt;strong&gt;attract each other&lt;/strong&gt; through van der Waals forces.&lt;/p&gt;</description>
    </item>
    <item>
      <title>Non-Ideal Mixtures</title>
      <link>//localhost:1313/mixtures/2_nonideal.html</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>//localhost:1313/mixtures/2_nonideal.html</guid>
      <description>&lt;div class=&#34;page&#34;&gt;&#xA;&lt;div class=&#34;stepLog twoColumn&#34;&gt;&#xA;&#xA;&lt;script&gt;&#xA;    var sim = createSimulation({&#xA;        initialize: function(simulation) {&#xA;&#x9;&#x9;&#x9;var p = simulation.parameters;&#xA;&#x9;&#x9;&#x9;p.thermostatDeterministicStrength = 0.3;&#xA;&#x9;&#x9;&#x9;p.thermostatTemperature = 8;&#xA;&#x9;&#x9;&#x9;setBoxWidth(simulation, 80);&#xA;&#xA;&#x9;&#x9;&#x9;// Type A particles&#xA;&#x9;&#x9;&#x9;var countA = 50;&#xA;&#x9;&#x9;&#x9;for (var i = 0; i &lt; countA; i++) {&#xA;&#x9;&#x9;&#x9;&#x9;var particle = new Particle();&#xA;&#x9;&#x9;&#x9;&#x9;particle.type = 0;&#xA;&#x9;&#x9;&#x9;&#x9;randomDiscInRect(particle.position, particle.radius, simulation.boxBounds);&#xA;&#x9;&#x9;&#x9;&#x9;v2.set(particle.velocity, randomGaussian(), randomGaussian());&#xA;&#x9;&#x9;&#x9;&#x9;v2.scale(particle.velocity, particle.velocity, 6);&#xA;&#x9;&#x9;&#x9;&#x9;addParticle(simulation, particle);&#xA;&#x9;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;&#x9;// Type B particles (red)&#xA;&#x9;&#x9;&#x9;var countB = 50;&#xA;&#x9;&#x9;&#x9;for (var i = 0; i &lt; countB; i++) {&#xA;&#x9;&#x9;&#x9;&#x9;var particle = new Particle();&#xA;&#x9;&#x9;&#x9;&#x9;particle.type = 1;&#xA;&#x9;&#x9;&#x9;&#x9;particle.color = Color.gray;&#xA;&#x9;&#x9;&#x9;&#x9;randomDiscInRect(particle.position, particle.radius, simulation.boxBounds);&#xA;&#x9;&#x9;&#x9;&#x9;v2.set(particle.velocity, randomGaussian(), randomGaussian());&#xA;&#x9;&#x9;&#x9;&#x9;v2.scale(particle.velocity, particle.velocity, 6);&#xA;&#x9;&#x9;&#x9;&#x9;addParticle(simulation, particle);&#xA;&#x9;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;&#x9;// Set up interactions&#xA;&#x9;&#x9;&#x9;var ljAA = new LennardJonesInteraction();&#xA;&#x9;&#x9;&#x9;ljAA.strength = 3;&#xA;&#x9;&#x9;&#x9;setInteraction(simulation, 0, 0, ljAA);&#xA;&#xA;&#x9;&#x9;&#x9;var ljBB = new LennardJonesInteraction();&#xA;&#x9;&#x9;&#x9;ljBB.strength = 3;&#xA;&#x9;&#x9;&#x9;setInteraction(simulation, 1, 1, ljBB);&#xA;&#xA;&#x9;&#x9;&#x9;var ljAB = new LennardJonesInteraction();&#xA;&#x9;&#x9;&#x9;ljAB.strength = 3;&#xA;&#x9;&#x9;&#x9;setInteraction(simulation, 0, 1, ljAB);&#xA;&#xA;&#x9;&#x9;&#x9;setToolbarAvailableTools(simulation.toolbar, [&#34;move&#34;, &#34;repel&#34;]);&#xA;        },&#xA;    });&#xA;&#xA;    var crossInteractionStrength = 3;&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h2&gt;Non-Ideal Mixtures&lt;/h2&gt;&#xA;&#xA;&lt;p&gt;Real molecules interact differently depending on what they&#39;re near. A-A interactions might differ from A-B interactions.&lt;/p&gt;</description>
    </item>
    <item>
      <title>Phase Transitions</title>
      <link>//localhost:1313/vanderwaals/2_phase_diagram.html</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>//localhost:1313/vanderwaals/2_phase_diagram.html</guid>
      <description>&lt;div class=&#34;page&#34;&gt;&#xA;&lt;div class=&#34;stepLog twoColumn&#34;&gt;&#xA;&#xA;&lt;script&gt;&#xA;    var sim = createSimulation({&#xA;        initialize: function(simulation) {&#xA;&#x9;&#x9;&#x9;var p = simulation.parameters;&#xA;&#x9;&#x9;&#x9;p.thermostatDeterministicStrength = 1;&#xA;&#x9;&#x9;&#x9;p.thermostatTemperature = 0.5;&#xA;&#x9;&#x9;&#x9;setBoxWidth(simulation, 50);&#xA;&#xA;            var particleCount = 37;&#xA;            for (var particleIndex = 0; particleIndex &lt; particleCount; particleIndex++) {&#xA;                var particle = new Particle();&#xA;                hexagonalLatticePosition(particle.position, particleIndex, 2);&#xA;                addParticle(simulation, particle);&#xA;            }&#xA;&#xA;            var displacement = v2.alloc();&#xA;            var displacementMagnitude = 0.01;&#xA;            for (var particleIndex = 0; particleIndex &lt; simulation.particles.length; particleIndex++) {&#xA;                var particle = simulation.particles[particleIndex];&#xA;                v2.set(displacement, randomGaussian(), randomGaussian());&#xA;                v2.scaleAndAdd(particle.position, particle.position, &#xA;                    displacement, displacementMagnitude);&#xA;            }&#xA;            v2.free(displacement);&#xA;&#xA;            var ljInteraction = new LennardJonesInteraction();&#xA;            ljInteraction.strength = 10;&#xA;            setInteraction(simulation, 0, 0, ljInteraction);&#xA;&#xA;            setToolbarAvailableTools(simulation.toolbar, [&#34;move&#34;]);&#xA;        }&#xA;    });&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h2&gt;Phase Transitions&lt;/h2&gt;&#xA;&#xA;&lt;p&gt;The van der Waals equation predicts something the ideal gas law cannot: &lt;strong&gt;phase transitions&lt;/strong&gt;.&lt;/p&gt;</description>
    </item>
    <item>
      <title>Pressure &amp; Temperature</title>
      <link>//localhost:1313/ideal/2_pressure_temperature.html</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>//localhost:1313/ideal/2_pressure_temperature.html</guid>
      <description>&lt;div class=&#34;page&#34;&gt;&#xA;&lt;div class=&#34;stepLog twoColumn&#34;&gt;&#xA;&#xA;&lt;script&gt;&#xA;    var sim = createSimulation({&#xA;        initialize: function(simulation) {&#xA;&#x9;&#x9;&#x9;var p = simulation.parameters;&#xA;&#x9;&#x9;&#x9;p.isOnlyHardSpheres = true;&#xA;&#x9;&#x9;&#x9;p.thermostatDeterministicStrength = 1;&#xA;&#x9;&#x9;&#x9;p.thermostatTemperature = 5;&#xA;&#x9;&#x9;&#x9;setBoxWidth(simulation, 80);&#xA;&#xA;&#x9;&#x9;&#x9;var particleCount = 120;&#xA;&#x9;&#x9;&#x9;for (var i = 0; i &lt; particleCount; i++) {&#xA;&#x9;&#x9;&#x9;&#x9;var particle = new Particle();&#xA;&#x9;&#x9;&#x9;&#x9;randomDiscInRect(particle.position, particle.radius, simulation.boxBounds);&#xA;&#x9;&#x9;&#x9;&#x9;v2.set(particle.velocity, randomGaussian(), randomGaussian());&#xA;&#x9;&#x9;&#x9;&#x9;v2.scale(particle.velocity, particle.velocity, 5);&#xA;&#x9;&#x9;&#x9;&#x9;addParticle(simulation, particle);&#xA;&#x9;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;&#x9;setToolbarAvailableTools(simulation.toolbar, [&#34;move&#34;]);&#xA;        },&#xA;    });&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h2&gt;Pressure &amp; Temperature: Gay-Lussac&#39;s Law&lt;/h2&gt;&#xA;&#xA;&lt;p&gt;Now let&#39;s keep the volume fixed and change the &lt;strong&gt;temperature&lt;/strong&gt; instead.&lt;/p&gt;</description>
    </item>
    <item>
      <title>Pressure &amp; Volume</title>
      <link>//localhost:1313/ideal/1_pressure_volume.html</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>//localhost:1313/ideal/1_pressure_volume.html</guid>
      <description>&lt;div class=&#34;page&#34;&gt;&#xA;&lt;div class=&#34;stepLog twoColumn&#34;&gt;&#xA;&#xA;&lt;script&gt;&#xA;    var sim = createSimulation({&#xA;        initialize: function(simulation) {&#xA;&#x9;&#x9;&#x9;var p = simulation.parameters;&#xA;&#x9;&#x9;&#x9;p.isOnlyHardSpheres = true;&#xA;&#x9;&#x9;&#x9;setBoxWidth(simulation, 100);&#xA;&#xA;&#x9;&#x9;&#x9;var particleCount = 150;&#xA;&#x9;&#x9;&#x9;for (var i = 0; i &lt; particleCount; i++) {&#xA;&#x9;&#x9;&#x9;&#x9;var particle = new Particle();&#xA;&#x9;&#x9;&#x9;&#x9;randomDiscInRect(particle.position, particle.radius, simulation.boxBounds);&#xA;&#x9;&#x9;&#x9;&#x9;v2.set(particle.velocity, randomGaussian(), randomGaussian());&#xA;&#x9;&#x9;&#x9;&#x9;v2.scale(particle.velocity, particle.velocity, 8);&#xA;&#x9;&#x9;&#x9;&#x9;addParticle(simulation, particle);&#xA;&#x9;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;&#x9;setToolbarAvailableTools(simulation.toolbar, [&#34;move&#34;]);&#xA;        },&#xA;    });&#xA;&#xA;    var currentBoxWidth = 100;&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h2&gt;Pressure &amp; Volume: Boyle&#39;s Law&lt;/h2&gt;&#xA;&#xA;&lt;p&gt;What happens when you &lt;strong&gt;squeeze&lt;/strong&gt; a gas into a smaller space?&lt;/p&gt;</description>
    </item>
    <item>
      <title>Pressure is Momentum</title>
      <link>//localhost:1313/kinetic/2_pressure_momentum.html</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>//localhost:1313/kinetic/2_pressure_momentum.html</guid>
      <description>&lt;div class=&#34;page&#34;&gt;&#xA;&lt;div class=&#34;stepLog twoColumn&#34;&gt;&#xA;&#xA;&lt;script&gt;&#xA;    var wallDetectorSim = createSimulation({&#xA;        initialize: function(simulation) {&#xA;            var p = simulation.parameters;&#xA;&#x9;&#x9;&#x9;p.isOnlyHardSpheres = true;&#xA;            p.dragStrength = 2;&#xA;&#x9;&#x9;&#x9;setBoxWidth(simulation, 40);&#xA;&#xA;            var particle = new Particle();&#xA;&#x9;&#x9;&#x9;particle.radius = 2;&#xA;            addParticle(simulation, particle);&#xA;&#xA;&#x9;&#x9;&#x9;setToolbarAvailableTools(simulation.toolbar, [&#34;move&#34;]);&#xA;        },&#xA;    });&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h2&gt;Pressure IS Momentum Transfer&lt;/h2&gt;&#xA;&#xA;&lt;p&gt;Let&#39;s zoom in on what pressure really means at the particle level.&lt;/p&gt;&#xA;&#xA;&lt;p&gt;Here&#39;s a single, large particle. Throw it at a wall!&lt;/p&gt;&#xA;&#xA;&lt;script&gt;&#xA;&#x9;createTimeSeriesHere({&#xA;&#x9;&#x9;timeRange: 50,&#xA;&#x9;&#x9;yMax: 10,&#xA;&#x9;&#x9;update: function(graph) {&#xA;&#x9;&#x9;&#x9;return {time: wallDetectorSim.time, data: [getTotalPressure(wallDetectorSim)]};&#xA;&#x9;&#x9;},&#xA;&#x9;});&#xA;&lt;/script&gt;&#xA;&#xA;&lt;script&gt;&#xA;&#x9;cue(function() {&#xA;&#x9;&#x9;var pressure = getTotalPressure(wallDetectorSim);&#xA;&#x9;&#x9;return (pressure &gt; 1);&#xA;&#x9;});&#xA;&#x9;endStep();&#xA;&lt;/script&gt;&#xA;&#xA;&lt;p&gt;See that spike in the graph? That&#39;s the &lt;strong&gt;momentum transfer&lt;/strong&gt; — the particle hits the wall, reverses direction, and pushes the wall outward in the process.&lt;/p&gt;</description>
    </item>
    <item>
      <title>PV = nRT</title>
      <link>//localhost:1313/ideal/3_pvnrt.html</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>//localhost:1313/ideal/3_pvnrt.html</guid>
      <description>&lt;div class=&#34;page&#34;&gt;&#xA;&lt;div class=&#34;stepLog twoColumn&#34;&gt;&#xA;&#xA;&lt;script&gt;&#xA;    var sim = createSimulation({&#xA;        initialize: function(simulation) {&#xA;&#x9;&#x9;&#x9;var p = simulation.parameters;&#xA;&#x9;&#x9;&#x9;p.isOnlyHardSpheres = true;&#xA;&#x9;&#x9;&#x9;p.thermostatDeterministicStrength = 1;&#xA;&#x9;&#x9;&#x9;p.thermostatTemperature = 10;&#xA;&#x9;&#x9;&#x9;setBoxWidth(simulation, 80);&#xA;&#xA;&#x9;&#x9;&#x9;var particleCount = 100;&#xA;&#x9;&#x9;&#x9;for (var i = 0; i &lt; particleCount; i++) {&#xA;&#x9;&#x9;&#x9;&#x9;var particle = new Particle();&#xA;&#x9;&#x9;&#x9;&#x9;randomDiscInRect(particle.position, particle.radius, simulation.boxBounds);&#xA;&#x9;&#x9;&#x9;&#x9;v2.set(particle.velocity, randomGaussian(), randomGaussian());&#xA;&#x9;&#x9;&#x9;&#x9;v2.scale(particle.velocity, particle.velocity, 6);&#xA;&#x9;&#x9;&#x9;&#x9;addParticle(simulation, particle);&#xA;&#x9;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;&#x9;setToolbarAvailableTools(simulation.toolbar, [&#34;move&#34;, &#34;create&#34;]);&#xA;        },&#xA;    });&#xA;&#xA;    var currentBoxWidth = 80;&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h2&gt;Putting It Together: PV = nRT&lt;/h2&gt;&#xA;&#xA;&lt;div class=&#34;equation&#34;&gt;PV = nRT&lt;/div&gt;&#xA;&#xA;&lt;p&gt;This is the &lt;strong&gt;ideal gas law&lt;/strong&gt;. It combines everything we&#39;ve seen:&lt;/p&gt;</description>
    </item>
    <item>
      <title>Temperature is Motion</title>
      <link>//localhost:1313/kinetic/1_temperature_motion.html</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>//localhost:1313/kinetic/1_temperature_motion.html</guid>
      <description>&lt;div class=&#34;page&#34;&gt;&#xA;&lt;div class=&#34;stepLog twoColumn&#34;&gt;&#xA;&#xA;&lt;script&gt;&#xA;    var sim = createSimulation({&#xA;        initialize: function(simulation) {&#xA;&#x9;&#x9;&#x9;var p = simulation.parameters;&#xA;&#x9;&#x9;&#x9;p.isOnlyHardSpheres = true;&#xA;&#x9;&#x9;&#x9;p.thermostatDeterministicStrength = 1;&#xA;&#x9;&#x9;&#x9;p.thermostatTemperature = 5;&#xA;&#x9;&#x9;&#x9;setBoxWidth(simulation, 80);&#xA;&#xA;&#x9;&#x9;&#x9;var particleCount = 80;&#xA;&#x9;&#x9;&#x9;for (var i = 0; i &lt; particleCount; i++) {&#xA;&#x9;&#x9;&#x9;&#x9;var particle = new Particle();&#xA;&#x9;&#x9;&#x9;&#x9;randomDiscInRect(particle.position, particle.radius, simulation.boxBounds);&#xA;&#x9;&#x9;&#x9;&#x9;v2.set(particle.velocity, randomGaussian(), randomGaussian());&#xA;&#x9;&#x9;&#x9;&#x9;v2.scale(particle.velocity, particle.velocity, 5);&#xA;&#x9;&#x9;&#x9;&#x9;addParticle(simulation, particle);&#xA;&#x9;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;&#x9;setToolbarAvailableTools(simulation.toolbar, [&#34;move&#34;]);&#xA;        },&#xA;    });&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h2&gt;Temperature IS Motion&lt;/h2&gt;&#xA;&#xA;&lt;p&gt;Temperature isn&#39;t some mysterious abstract quantity. It&#39;s simply a measure of &lt;strong&gt;how fast the particles are moving&lt;/strong&gt;.&lt;/p&gt;</description>
    </item>
    <item>
      <title>Welcome</title>
