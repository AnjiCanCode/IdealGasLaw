    <item>
      <title>Correcting the Ideal Gas Law</title>
      <link>//localhost:1313/vanderwaals/1_corrections/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>//localhost:1313/vanderwaals/1_corrections/</guid>
      <description>&lt;div class=&#34;page&#34;&gt;&#xA;&lt;div class=&#34;stepLog twoColumn&#34;&gt;&#xA;&#xA;&lt;h2&gt;The Van der Waals Equation&lt;/h2&gt;&#xA;&#xA;&lt;div class=&#34;equation&#34;&gt;(P + a·n²/V²)(V − nb) = nRT&lt;/div&gt;&#xA;&#xA;&lt;p&gt;This equation makes two corrections to the ideal gas law:&lt;/p&gt;&#xA;&#xA;&lt;ul&gt;&#xA;  &lt;li&gt;&lt;strong&gt;+ a·n²/V²&lt;/strong&gt;, corrects for intermolecular &lt;strong&gt;attraction&lt;/strong&gt; reducing the measured pressure&lt;/li&gt;&#xA;  &lt;li&gt;&lt;strong&gt;− nb&lt;/strong&gt;, corrects for the &lt;strong&gt;excluded volume&lt;/strong&gt; of the molecules themselves&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&#xA;&lt;p&gt;Let&#39;s compare. On the right are &lt;strong&gt;two simulations running side by side&lt;/strong&gt;.&lt;/p&gt;&#xA;&#xA;&lt;script&gt;&#xA;    var idealSim = createSimulation({&#xA;&#x9;&#x9;pixelWidth: 400,&#xA;&#x9;&#x9;pixelHeight: 200,&#xA;        initialize: function(simulation) {&#xA;&#x9;&#x9;&#x9;var p = simulation.parameters;&#xA;&#x9;&#x9;&#x9;p.isOnlyHardSpheres = true;&#xA;&#x9;&#x9;&#x9;p.thermostatDeterministicStrength = 0.5;&#xA;&#x9;&#x9;&#x9;p.thermostatTemperature = 10;&#xA;&#x9;&#x9;&#x9;setBoxWidth(simulation, 60);&#xA;&#xA;&#x9;&#x9;&#x9;var particleCount = 80;&#xA;&#x9;&#x9;&#x9;for (var i = 0; i &lt; particleCount; i++) {&#xA;&#x9;&#x9;&#x9;&#x9;var particle = new Particle();&#xA;&#x9;&#x9;&#x9;&#x9;randomDiscInRect(particle.position, particle.radius, simulation.boxBounds);&#xA;&#x9;&#x9;&#x9;&#x9;v2.set(particle.velocity, randomGaussian(), randomGaussian());&#xA;&#x9;&#x9;&#x9;&#x9;v2.scale(particle.velocity, particle.velocity, 6);&#xA;&#x9;&#x9;&#x9;&#x9;addParticle(simulation, particle);&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;setToolbarAvailableTools(simulation.toolbar, [&#34;move&#34;]);&#xA;        },&#xA;    });&#xA;&#xA;&#x9;var realSim = createSimulation({&#xA;&#x9;&#x9;pixelWidth: 400,&#xA;&#x9;&#x9;pixelHeight: 200,&#xA;        initialize: function(simulation) {&#xA;&#x9;&#x9;&#x9;var p = simulation.parameters;&#xA;&#x9;&#x9;&#x9;p.thermostatDeterministicStrength = 0.5;&#xA;&#x9;&#x9;&#x9;p.thermostatTemperature = 10;&#xA;&#x9;&#x9;&#x9;setBoxWidth(simulation, 60);&#xA;&#xA;&#x9;&#x9;&#x9;var particleCount = 80;&#xA;&#x9;&#x9;&#x9;var particles = [];&#xA;&#x9;&#x9;&#x9;for (var i = 0; i &lt; particleCount; i++) {&#xA;&#x9;&#x9;&#x9;&#x9;var particle = new Particle();&#xA;&#x9;&#x9;&#x9;&#x9;particles.push(particle);&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;addParticlesRandomlyAround(simulation, particles, v2(0, 0));&#xA;&#xA;&#x9;&#x9;&#x9;var ljInteraction = new LennardJonesInteraction();&#xA;&#x9;&#x9;&#x9;ljInteraction.strength = 5;&#xA;&#x9;&#x9;&#x9;setInteraction(simulation, 0, 0, ljInteraction);&#xA;&#x9;&#x9;&#x9;setToolbarAvailableTools(simulation.toolbar, [&#34;move&#34;]);&#xA;        },&#xA;    });&#xA;&lt;/script&gt;&#xA;&#xA;&lt;p&gt;&lt;strong&gt;Top:&lt;/strong&gt; Ideal gas (no attraction, point particles)&lt;br&gt;&#xA;&lt;strong&gt;Bottom:&lt;/strong&gt; Real gas (attraction + finite size)&lt;/p&gt;</description>
    </item>
    <item>
      <title>Phase Transitions</title>
      <link>//localhost:1313/vanderwaals/2_phase_diagram/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>//localhost:1313/vanderwaals/2_phase_diagram/</guid>
      <description>&lt;div class=&#34;page&#34;&gt;&#xA;&lt;div class=&#34;stepLog twoColumn&#34;&gt;&#xA;&#xA;&lt;script&gt;&#xA;    var sim = createSimulation({&#xA;        initialize: function(simulation) {&#xA;&#x9;&#x9;&#x9;var p = simulation.parameters;&#xA;&#x9;&#x9;&#x9;p.thermostatDeterministicStrength = 1;&#xA;&#x9;&#x9;&#x9;p.thermostatTemperature = 0.5;&#xA;&#x9;&#x9;&#x9;setBoxWidth(simulation, 50);&#xA;&#xA;            var particleCount = 37;&#xA;            for (var particleIndex = 0; particleIndex &lt; particleCount; particleIndex++) {&#xA;                var particle = new Particle();&#xA;                hexagonalLatticePosition(particle.position, particleIndex, 2);&#xA;                addParticle(simulation, particle);&#xA;            }&#xA;&#xA;            var displacement = v2.alloc();&#xA;            var displacementMagnitude = 0.01;&#xA;            for (var particleIndex = 0; particleIndex &lt; simulation.particles.length; particleIndex++) {&#xA;                var particle = simulation.particles[particleIndex];&#xA;                v2.set(displacement, randomGaussian(), randomGaussian());&#xA;                v2.scaleAndAdd(particle.position, particle.position, &#xA;                    displacement, displacementMagnitude);&#xA;            }&#xA;            v2.free(displacement);&#xA;&#xA;            var ljInteraction = new LennardJonesInteraction();&#xA;            ljInteraction.strength = 10;&#xA;            setInteraction(simulation, 0, 0, ljInteraction);&#xA;&#xA;            setToolbarAvailableTools(simulation.toolbar, [&#34;move&#34;]);&#xA;        }&#xA;    });&#xA;&lt;/script&gt;&#xA;&#xA;&lt;h2&gt;Phase Transitions&lt;/h2&gt;&#xA;&#xA;&lt;p&gt;The van der Waals equation predicts something the ideal gas law cannot: &lt;strong&gt;phase transitions&lt;/strong&gt;.&lt;/p&gt;</description>
    </item>
